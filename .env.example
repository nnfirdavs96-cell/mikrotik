APP_NAME=WiFi Access Manager
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0-mvp

DATABASE_URL=sqlite:///./wifi_access.db
SECRET_KEY=change_this_secret_key
API_SECRET_KEY=change_this_api_key
# Fernet key to encrypt MikroTik passwords in the DB. Leave empty to derive
# it from SECRET_KEY. Generate a dedicated key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_password

DEFAULT_ALLOWED_LIST=allowed_clients
DEFAULT_GUEST_NETWORK=192.168.50.0/24

SMS_PROVIDER=mock
PAYMENT_PROVIDER=mock

DEFAULT_CURRENCY=TJS

# OTP settings
OTP_LENGTH=6
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=3
# OTP rate limiting (anti-spam): max codes per phone per window + resend cooldown
OTP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MINUTES=60
OTP_RESEND_COOLDOWN_SECONDS=60

# MikroTik API timeout (seconds)
MIKROTIK_TIMEOUT=10

# If true, portal refuses registration when DHCP lease (MAC) is not found.
# Keep false for MVP/testing without a real MikroTik.
PORTAL_REQUIRE_LEASE=false

# ===== Stage 2 =====

# Access control mode: address_list (firewall allowed_clients) or hotspot.
ACCESS_MODE=address_list
ACCESS_HOTSPOT_PROFILE=

# Speed limits: apply per-tariff speed via MikroTik simple queues on activate.
APPLY_QUEUES=true
QUEUE_PREFIX=wam

# In-app scheduler (replaces cron). Auto-deactivates expired clients.
SCHEDULER_ENABLED=true
EXPIRE_INTERVAL_MINUTES=10
# Traffic-quota enforcement (reads simple-queue byte counters).
TRAFFIC_CHECK_ENABLED=false
TRAFFIC_CHECK_INTERVAL_MINUTES=15
# Periodic refresh of client IP/hostname/last_seen from DHCP leases (by MAC)
LEASE_SYNC_ENABLED=false
LEASE_SYNC_INTERVAL_MINUTES=5

# Public base URL of this app (used for payment return/callback + captive redirect).
PUBLIC_BASE_URL=http://192.168.0.100:8000

# Captive portal redirect: when true, foreign/intercepted requests are sent to
# the portal so the device shows "Sign in to network". Requires MikroTik
# dst-nat rules (see README). Set the portal URL via PUBLIC_BASE_URL or below.
CAPTIVE_REDIRECT_ENABLED=false
CAPTIVE_PORTAL_URL=

# ----- Real SMS provider (set SMS_PROVIDER=http to enable) -----
# SMS_PROVIDER=http
SMS_API_URL=
SMS_API_KEY=
SMS_API_METHOD=POST
SMS_API_AUTH_HEADER=Authorization
SMS_API_AUTH_PREFIX=Bearer
SMS_SENDER=
SMS_PHONE_PARAM=phone
SMS_TEXT_PARAM=text
SMS_SENDER_PARAM=from
SMS_EXTRA_PARAMS=
SMS_JSON_BODY=true

# ----- Real payment gateway (set PAYMENT_PROVIDER=http to enable) -----
# PAYMENT_PROVIDER=http
PAYMENT_API_URL=
PAYMENT_API_KEY=
PAYMENT_API_AUTH_HEADER=Authorization
PAYMENT_API_AUTH_PREFIX=Bearer
PAYMENT_RETURN_URL=
PAYMENT_CALLBACK_URL=
PAYMENT_PAY_URL_FIELD=payment_url
PAYMENT_ID_FIELD=id
